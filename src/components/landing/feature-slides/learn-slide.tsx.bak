"use client";

import * as React from "react";
import { motion, AnimatePresence } from "motion/react";
import { cn } from "@/lib/utils";
import { zodiacUIConfig } from "@/config/zodiac-ui";
import { planetUIConfig } from "@/config/planet-ui";
import { houseUIConfig } from "@/config/house-ui";
import { aspectUIConfig } from "@/config/aspects-ui";
import { elementUIConfig } from "@/config/elements-ui";
import { compositionalSigns } from "@/astrology/signs";
import { compositionalHouses } from "@/astrology/houses";
import { compositionalAspects } from "@/astrology/aspects";
import { ELEMENTS_LEARN, type ElementType } from "@/astrology/elements";
import {
  TbZodiacAries,
  TbZodiacTaurus,
  TbZodiacGemini,
  TbZodiacCancer,
  TbZodiacLeo,
  TbZodiacVirgo,
  TbZodiacLibra,
  TbZodiacScorpio,
  TbZodiacSagittarius,
  TbZodiacCapricorn,
  TbZodiacAquarius,
  TbZodiacPisces,
} from "react-icons/tb";
import {
  GiFlame,
  GiStonePile,
  GiTornado,
  GiWaveCrest,
} from "react-icons/gi";
import {
  FaUser,
  FaCoins,
  FaComments,
  FaHome,
  FaTheaterMasks,
  FaHeartbeat,
  FaHandshake,
  FaSkull,
  FaGlobe,
  FaCrown,
  FaUsers,
  FaMoon,
} from "react-icons/fa";
import type { IconType } from "react-icons";

/* ── Tab Definitions ──────────────────────────────────────── */

type TabId = "signs" | "houses" | "planets" | "aspects" | "elements";

interface TabDef {
  id: TabId;
  label: string;
  icon: IconType;
  accentColor: string; // CSS variable or tailwind color
  glowClass: string;
}

const TABS: TabDef[] = [
  {
    id: "signs",
    label: "Signs",
    icon: TbZodiacAries,
    accentColor: "var(--primary)",
    glowClass: "bg-primary/20",
  },
  {
    id: "houses",
    label: "Houses",
    icon: FaHome,
    accentColor: "var(--earth-primary)",
    glowClass: "bg-earth/20",
  },
  {
    id: "planets",
    label: "Planets",
    icon: FaGlobe,
    accentColor: "var(--galactic)",
    glowClass: "bg-galactic/20",
  },
  {
    id: "aspects",
    label: "Aspects",
    icon: TbZodiacGemini,
    accentColor: "var(--aspect-conjunction)",
    glowClass: "bg-amber-400/20",
  },
  {
    id: "elements",
    label: "Elements",
    icon: GiFlame,
    accentColor: "var(--fire-primary)",
    glowClass: "bg-fire/20",
  },
];

/* ── Zodiac icon map (for rendering in signs grid) ────────── */

const ZODIAC_ICON_MAP: Record<string, IconType> = {
  aries: TbZodiacAries,
  taurus: TbZodiacTaurus,
  gemini: TbZodiacGemini,
  cancer: TbZodiacCancer,
  leo: TbZodiacLeo,
  virgo: TbZodiacVirgo,
  libra: TbZodiacLibra,
  scorpio: TbZodiacScorpio,
  sagittarius: TbZodiacSagittarius,
  capricorn: TbZodiacCapricorn,
  aquarius: TbZodiacAquarius,
  pisces: TbZodiacPisces,
};

const HOUSE_ICON_MAP: Record<number, IconType> = {
  1: FaUser,
  2: FaCoins,
  3: FaComments,
  4: FaHome,
  5: FaTheaterMasks,
  6: FaHeartbeat,
  7: FaHandshake,
  8: FaSkull,
  9: FaGlobe,
  10: FaCrown,
  11: FaUsers,
  12: FaMoon,
};

const ELEMENT_ICON_MAP: Record<string, IconType> = {
  Fire: GiFlame,
  Earth: GiStonePile,
  Air: GiTornado,
  Water: GiWaveCrest,
};

/* ── Signs Panel ──────────────────────────────────────────── */

function SignsPanel() {
  const [selectedSign, setSelectedSign] = React.useState<string | null>(null);
  const signs = compositionalSigns;

  const selectedData = selectedSign
    ? signs.find((s) => s.id === selectedSign)
    : null;
  const selectedUI = selectedSign ? zodiacUIConfig[selectedSign] : null;

  return (
    <div className="flex gap-6 h-full min-h-0">
      {/* Sign grid */}
      <div className="flex-1 min-w-0">
        <div className="grid grid-cols-4 gap-2 auto-rows-min">
          {signs.map((sign) => {
            const ui = zodiacUIConfig[sign.id];
            const Icon = ZODIAC_ICON_MAP[sign.id];
            const isSelected = selectedSign === sign.id;
            return (
              <motion.button
                key={sign.id}
                onClick={() =>
                  setSelectedSign(isSelected ? null : sign.id)
                }
                className={cn(
                  "group relative flex flex-col items-center gap-1.5 p-3 rounded-xl border transition-all duration-300 cursor-pointer",
                  isSelected
                    ? "bg-primary/10 border-primary/30 shadow-[0_0_20px_rgba(var(--primary-rgb),0.1)]"
                    : "bg-card/30 border-border/30 hover:bg-card/50 hover:border-border/60",
                )}
                whileHover={{ y: -2 }}
                whileTap={{ scale: 0.97 }}
              >
                <Icon
                  className={cn(
                    "size-7 transition-colors duration-300",
                    isSelected ? "text-primary" : "text-muted-foreground group-hover:text-foreground",
                  )}
                />
                <span
                  className={cn(
                    "text-[10px] font-medium tracking-wider uppercase transition-colors duration-300",
                    isSelected ? "text-primary" : "text-muted-foreground group-hover:text-foreground",
                  )}
                >
                  {sign.name.slice(0, 3)}
                </span>
                <span className="text-[8px] text-muted-foreground/60">
                  {sign.dates.split(" - ")[0]}
                </span>
              </motion.button>
            );
          })}
        </div>
      </div>

      {/* Selected sign detail */}
      <AnimatePresence mode="wait">
        {selectedData && selectedUI && (
          <motion.div
            key={selectedData.id}
            initial={{ opacity: 0, x: 20 }}
            animate={{ opacity: 1, x: 0 }}
            exit={{ opacity: 0, x: -20 }}
            transition={{ duration: 0.3, ease: "easeOut" }}
            className="w-[280px] shrink-0 border-l border-border/30 pl-6 flex flex-col"
          >
            {/* Constellation */}
            <div className="relative w-full aspect-square max-w-[200px] mx-auto mb-4">
              <div className="absolute inset-0 bg-primary/5 rounded-full blur-2xl" />
              <img
                src={selectedUI.constellationUrl}
                alt={`${selectedData.name} constellation`}
                className="relative w-full h-full object-contain opacity-80"
                style={{ filter: "brightness(1.2)" }}
              />
            </div>

            {/* Sign info */}
            <div className="space-y-3 flex-1">
              <div>
                <h4 className="text-lg font-serif tracking-tight text-foreground">
                  {selectedData.name}
                </h4>
                <p className="text-[10px] uppercase tracking-[0.2em] text-primary font-bold">
                  {selectedData.archetypeName}
                </p>
              </div>

              <div className="flex gap-2 flex-wrap">
                <span className="text-[9px] uppercase tracking-widest font-medium px-2 py-0.5 rounded-full bg-card border border-border/40 text-muted-foreground">
                  {selectedData.element}
                </span>
                <span className="text-[9px] uppercase tracking-widest font-medium px-2 py-0.5 rounded-full bg-card border border-border/40 text-muted-foreground">
                  {selectedData.modality}
                </span>
              </div>

              <p className="text-xs text-muted-foreground leading-relaxed line-clamp-4">
                {selectedData.essenceFull}
              </p>

              <div className="pt-2">
                <p className="text-[9px] uppercase tracking-widest text-muted-foreground/60 font-medium mb-1.5">
                  Motto
                </p>
                <p className="text-xs font-serif italic text-foreground/80">
                  "{selectedData.motto}"
                </p>
              </div>

              <div className="pt-1">
                <p className="text-[9px] uppercase tracking-widest text-muted-foreground/60 font-medium mb-1.5">
                  Core Desire
                </p>
                <p className="text-xs text-muted-foreground">
                  {selectedData.coreDesire}
                </p>
              </div>
            </div>
          </motion.div>
        )}
      </AnimatePresence>
    </div>
  );
}

/* ── Houses Panel ─────────────────────────────────────────── */

function HousesPanel() {
  const [selectedHouse, setSelectedHouse] = React.useState<number | null>(null);
  const houses = compositionalHouses;

  const selectedData = selectedHouse
    ? houses.find((h) => h.id === selectedHouse)
    : null;

  return (
    <div className="flex gap-6 h-full min-h-0">
      {/* House grid */}
      <div className="flex-1 min-w-0">
        <div className="grid grid-cols-4 gap-2 auto-rows-min">
          {houses.map((house) => {
            const Icon = HOUSE_ICON_MAP[house.id];
            const ui = houseUIConfig[house.id];
            const isSelected = selectedHouse === house.id;
            return (
              <motion.button
                key={house.id}
                onClick={() =>
                  setSelectedHouse(isSelected ? null : house.id)
                }
                className={cn(
                  "group relative flex flex-col items-center gap-1.5 p-3 rounded-xl border transition-all duration-300 cursor-pointer",
                  isSelected
                    ? "bg-earth/10 border-earth/30"
                    : "bg-card/30 border-border/30 hover:bg-card/50 hover:border-border/60",
                )}
                whileHover={{ y: -2 }}
                whileTap={{ scale: 0.97 }}
              >
                {/* Roman numeral badge */}
                <div
                  className={cn(
                    "absolute -top-1.5 -right-1.5 size-5 rounded-full flex items-center justify-center text-[8px] font-bold border",
                    isSelected
                      ? "bg-earth/20 border-earth/40 text-earth"
                      : "bg-card border-border/40 text-muted-foreground",
                  )}
                >
                  {house.romanNumeral}
                </div>
                <Icon
                  className={cn(
                    "size-6 transition-colors duration-300",
                    isSelected ? "text-earth" : "text-muted-foreground group-hover:text-foreground",
                  )}
                />
                <span
                  className={cn(
                    "text-[9px] font-medium tracking-wider uppercase transition-colors duration-300",
                    isSelected ? "text-earth" : "text-muted-foreground group-hover:text-foreground",
                  )}
                >
                  {house.keyword}
                </span>
              </motion.button>
            );
          })}
        </div>
      </div>

      {/* Selected house detail */}
      <AnimatePresence mode="wait">
        {selectedData && (
          <motion.div
            key={selectedData.id}
            initial={{ opacity: 0, x: 20 }}
            animate={{ opacity: 1, x: 0 }}
            exit={{ opacity: 0, x: -20 }}
            transition={{ duration: 0.3, ease: "easeOut" }}
            className="w-[280px] shrink-0 border-l border-border/30 pl-6 flex flex-col"
          >
            <div className="space-y-3 flex-1">
              <div>
                <p className="text-[10px] uppercase tracking-[0.2em] text-earth font-bold mb-1">
                  {selectedData.romanNumeral} House
                </p>
                <h4 className="text-lg font-serif tracking-tight text-foreground">
                  {selectedData.archetypeName}
                </h4>
              </div>

              <div className="flex gap-2 flex-wrap">
                <span className="text-[9px] uppercase tracking-widest font-medium px-2 py-0.5 rounded-full bg-card border border-border/40 text-muted-foreground">
                  {selectedData.angularity}
                </span>
                <span className="text-[9px] uppercase tracking-widest font-medium px-2 py-0.5 rounded-full bg-card border border-border/40 text-muted-foreground">
                  {selectedData.naturalSign}
                </span>
              </div>

              <div className="pt-1">
                <p className="text-[9px] uppercase tracking-widest text-muted-foreground/60 font-medium mb-1.5">
                  Arena
                </p>
                <p className="text-xs text-muted-foreground">
                  {selectedData.primaryArena}
                </p>
              </div>

              <div className="pt-1">
                <p className="text-[9px] uppercase tracking-widest text-muted-foreground/60 font-medium mb-1.5">
                  Developmental Theme
                </p>
                <p className="text-xs text-muted-foreground leading-relaxed">
                  {selectedData.developmentalTheme}
                </p>
              </div>

              <div className="pt-1">
                <p className="text-[9px] uppercase tracking-widest text-muted-foreground/60 font-medium mb-1.5">
                  Manifestations
                </p>
                <ul className="space-y-1">
                  {selectedData.realWorldManifestations.map((m, i) => (
                    <li
                      key={i}
                      className="text-[11px] text-muted-foreground flex items-start gap-1.5"
                    >
                      <span className="mt-1.5 size-1 rounded-full bg-earth/40 shrink-0" />
                      {m}
                    </li>
                  ))}
                </ul>
              </div>

              <div className="pt-2">
                <p className="text-[9px] uppercase tracking-widest text-muted-foreground/60 font-medium mb-1">
                  Motto
                </p>
                <p className="text-xs font-serif italic text-foreground/80">
                  "{selectedData.motto}"
                </p>
              </div>
            </div>
          </motion.div>
        )}
      </AnimatePresence>
    </div>
  );
}

/* ── Planets Panel ────────────────────────────────────────── */

function PlanetsPanel() {
  const [selectedPlanet, setSelectedPlanet] = React.useState<string | null>(null);

  // Only show the main celestial bodies (not part_of_fortune, rising, etc.)
  const displayPlanets = Object.entries(planetUIConfig).filter(
    ([key]) =>
      !["part_of_fortune", "rising"].includes(key),
  );

  const selectedKey = selectedPlanet;
  const selectedUI = selectedKey ? planetUIConfig[selectedKey] : null;

  return (
    <div className="flex gap-6 h-full min-h-0">
      {/* Planet grid */}
      <div className="flex-1 min-w-0">
        <div className="grid grid-cols-4 gap-2 auto-rows-min">
          {displayPlanets.map(([key, planet]) => {
            const isSelected = selectedPlanet === key;
            const hasImage = !!planet.imageUrl;
            return (
              <motion.button
                key={key}
                onClick={() =>
                  setSelectedPlanet(isSelected ? null : key)
                }
                className={cn(
                  "group relative flex flex-col items-center gap-2 p-3 rounded-xl border transition-all duration-300 cursor-pointer",
                  isSelected
                    ? "border-border/60 bg-card/60 shadow-lg"
                    : "bg-card/30 border-border/30 hover:bg-card/50 hover:border-border/60",
                )}
                whileHover={{ y: -2 }}
                whileTap={{ scale: 0.97 }}
                style={
                  isSelected && planet.imageUrl
                    ? {
                        boxShadow: `0 0 30px ${planet.themeColor}20, 0 0 60px ${planet.themeColor}10`,
                      }
                    : undefined
                }
              >
                {hasImage ? (
                  <div className="relative size-10">
                    <div
                      className="absolute inset-0 rounded-full blur-md opacity-40"
                      style={{ backgroundColor: planet.themeColor }}
                    />
                    <img
                      src={planet.imageUrl}
                      alt={key}
                      className="relative size-full object-contain rounded-full"
                      style={{
                        transform: `scale(${planet.imageScale ?? 1})`,
                      }}
                    />
                  </div>
                ) : (
                  <div
                    className="size-10 rounded-full flex items-center justify-center text-xl border border-border/40"
                    style={{ color: planet.themeColor }}
                  >
                    {planet.rulerSymbol}
                  </div>
                )}
                <span
                  className={cn(
                    "text-[10px] font-medium tracking-wider capitalize transition-colors duration-300",
                    isSelected ? "text-foreground" : "text-muted-foreground group-hover:text-foreground",
                  )}
                >
                  {key.replace(/_/g, " ")}
                </span>
                <span
                  className="text-xs opacity-60"
                  style={{ color: planet.themeColor }}
                >
                  {planet.rulerSymbol}
                </span>
              </motion.button>
            );
          })}
        </div>
      </div>

      {/* Selected planet detail */}
      <AnimatePresence mode="wait">
        {selectedUI && selectedKey && (
          <motion.div
            key={selectedKey}
            initial={{ opacity: 0, x: 20 }}
            animate={{ opacity: 1, x: 0 }}
            exit={{ opacity: 0, x: -20 }}
            transition={{ duration: 0.3, ease: "easeOut" }}
            className="w-[280px] shrink-0 border-l border-border/30 pl-6 flex flex-col items-center"
          >
            {/* Large planet orb */}
            {selectedUI.imageUrl && (
              <div className="relative mb-6">
                <div
                  className="absolute inset-0 rounded-full blur-2xl opacity-30 scale-150"
                  style={{ backgroundColor: selectedUI.themeColor }}
                />
                <img
                  src={selectedUI.imageUrl}
                  alt={selectedKey}
                  className="relative size-32 object-contain rounded-full"
                  style={{
                    transform: `scale(${selectedUI.imageScale ?? 1})`,
                    filter: "brightness(1.15)",
                  }}
                />
              </div>
            )}

            <h4 className="text-lg font-serif tracking-tight text-foreground capitalize">
              {selectedKey.replace(/_/g, " ")}
            </h4>

            <div
              className="mt-2 size-14 rounded-full flex items-center justify-center text-2xl border border-border/30"
              style={{ color: selectedUI.themeColor }}
            >
              {selectedUI.rulerSymbol}
            </div>

            <p className="text-[10px] uppercase tracking-[0.2em] mt-3 font-bold" style={{ color: selectedUI.themeColor }}>
              Ruling Symbol
            </p>
          </motion.div>
        )}
      </AnimatePresence>
    </div>
  );
}

/* ── Aspects Panel ────────────────────────────────────────── */

function AspectsPanel() {
  const [selectedAspect, setSelectedAspect] = React.useState<string | null>(
    "conjunction",
  );
  const aspects = compositionalAspects;
  const majorAspects = aspects.filter((a) => a.category === "major");
  const minorAspects = aspects.filter((a) => a.category !== "major");

  const selectedData = selectedAspect
    ? aspects.find((a) => a.id === selectedAspect)
    : null;
  const selectedUI = selectedAspect ? aspectUIConfig[selectedAspect] : null;

  return (
    <div className="flex gap-6 h-full min-h-0">
      {/* Aspect list */}
      <div className="flex-1 min-w-0 overflow-y-auto pr-2 custom-scrollbar">
        <p className="text-[9px] uppercase tracking-[0.2em] text-muted-foreground/60 font-bold mb-2">
          Major Aspects
        </p>
        <div className="grid grid-cols-3 gap-1.5 mb-4">
          {majorAspects.map((aspect) => {
            const ui = aspectUIConfig[aspect.id];
            const isSelected = selectedAspect === aspect.id;
            return (
              <motion.button
                key={aspect.id}
                onClick={() => setSelectedAspect(aspect.id)}
                className={cn(
                  "group flex items-center gap-2 p-2.5 rounded-lg border transition-all duration-300 cursor-pointer",
                  isSelected
                    ? "bg-card/60 border-border/60"
                    : "bg-card/20 border-border/20 hover:bg-card/40 hover:border-border/40",
                )}
                whileTap={{ scale: 0.97 }}
              >
                {/* Aspect glyph */}
                <div className="relative size-8 shrink-0">
                  <svg
                    viewBox="0 0 24 24"
                    className="w-full h-full"
                    fill="none"
                    stroke={isSelected ? "currentColor" : "var(--muted-foreground)"}
                    strokeWidth={1.5}
                    style={isSelected ? { color: ui?.hexFallback } : undefined}
                  >
                    <path d={ui?.glyphPath ?? ""} />
                  </svg>
                </div>
                <div className="text-left min-w-0">
                  <p
                    className={cn(
                      "text-[11px] font-medium truncate transition-colors",
                      isSelected ? "text-foreground" : "text-muted-foreground group-hover:text-foreground",
                    )}
                  >
                    {aspect.name}
                  </p>
                  <p className="text-[9px] text-muted-foreground/60">
                    {aspect.degreesExact}
                  </p>
                </div>
              </motion.button>
            );
          })}
        </div>

        <p className="text-[9px] uppercase tracking-[0.2em] text-muted-foreground/60 font-bold mb-2">
          Minor & Harmonic
        </p>
        <div className="grid grid-cols-3 gap-1.5">
          {minorAspects.map((aspect) => {
            const ui = aspectUIConfig[aspect.id];
            const isSelected = selectedAspect === aspect.id;
            return (
              <motion.button
                key={aspect.id}
                onClick={() => setSelectedAspect(aspect.id)}
                className={cn(
                  "group flex items-center gap-2 p-2.5 rounded-lg border transition-all duration-300 cursor-pointer",
                  isSelected
                    ? "bg-card/60 border-border/60"
                    : "bg-card/20 border-border/20 hover:bg-card/40 hover:border-border/40",
                )}
                whileTap={{ scale: 0.97 }}
              >
                <div className="relative size-8 shrink-0">
                  <svg
                    viewBox="0 0 24 24"
                    className="w-full h-full"
                    fill="none"
                    stroke={isSelected ? "currentColor" : "var(--muted-foreground)"}
                    strokeWidth={1.5}
                    style={isSelected ? { color: ui?.hexFallback } : undefined}
                  >
                    <path d={ui?.glyphPath ?? ""} />
                  </svg>
                </div>
                <div className="text-left min-w-0">
                  <p
                    className={cn(
                      "text-[11px] font-medium truncate transition-colors",
                      isSelected ? "text-foreground" : "text-muted-foreground group-hover:text-foreground",
                    )}
                  >
                    {aspect.name}
                  </p>
                  <p className="text-[9px] text-muted-foreground/60">
                    {aspect.degreesExact}
                  </p>
                </div>
              </motion.button>
            );
          })}
        </div>
      </div>

      {/* Selected aspect detail */}
      <AnimatePresence mode="wait">
        {selectedData && selectedUI && (
          <motion.div
            key={selectedData.id}
            initial={{ opacity: 0, x: 20 }}
            animate={{ opacity: 1, x: 0 }}
            exit={{ opacity: 0, x: -20 }}
            transition={{ duration: 0.3, ease: "easeOut" }}
            className="w-[280px] shrink-0 border-l border-border/30 pl-6 flex flex-col overflow-y-auto"
          >
            {/* Large glyph */}
            <div
              className="relative mx-auto mb-5 size-28 flex items-center justify-center rounded-full border border-border/20"
              style={{
                background: `radial-gradient(circle at center, ${selectedUI.hexFallback}15 0%, transparent 70%)`,
              }}
            >
              <svg
                viewBox="0 0 24 24"
                className="size-16"
                fill="none"
                stroke={selectedUI.hexFallback}
                strokeWidth={1.2}
              >
                <path d={selectedUI.glyphPath} />
              </svg>
            </div>

            <div className="space-y-3 flex-1">
              <div>
                <h4 className="text-lg font-serif tracking-tight text-foreground">
                  {selectedData.name}
                </h4>
                <div className="flex gap-2 mt-1 flex-wrap">
                  <span
                    className="text-[9px] uppercase tracking-widest font-bold px-2 py-0.5 rounded-full border"
                    style={{
                      color: selectedUI.hexFallback,
                      borderColor: `${selectedUI.hexFallback}40`,
                      backgroundColor: `${selectedUI.hexFallback}10`,
                    }}
                  >
                    {selectedUI.badgeLabel}
                  </span>
                  <span className="text-[9px] uppercase tracking-widest font-medium px-2 py-0.5 rounded-full bg-card border border-border/40 text-muted-foreground">
                    {selectedData.degreesExact}
                  </span>
                  <span className="text-[9px] uppercase tracking-widest font-medium px-2 py-0.5 rounded-full bg-card border border-border/40 text-muted-foreground">
                    {selectedData.nature}
                  </span>
                </div>
              </div>

              <div className="flex gap-1.5 flex-wrap">
                {selectedData.coreKeywords.map((kw) => (
                  <span
                    key={kw}
                    className="text-[8px] uppercase tracking-wider font-medium px-1.5 py-0.5 rounded bg-card border border-border/30 text-muted-foreground"
                  >
                    {kw}
                  </span>
                ))}
              </div>

              <div className="pt-1">
                <p className="text-[9px] uppercase tracking-widest text-muted-foreground/60 font-medium mb-1.5">
                  Psychological Function
                </p>
                <p className="text-[11px] text-muted-foreground leading-relaxed line-clamp-5">
                  {selectedData.psychologicalFunction}
                </p>
              </div>

              <div className="pt-1">
                <p className="text-[9px] uppercase tracking-widest text-muted-foreground/60 font-medium mb-1.5">
                  Developmental Theme
                </p>
                <p className="text-[11px] text-muted-foreground leading-relaxed line-clamp-3">
                  {selectedData.developmentalTheme}
                </p>
              </div>
            </div>
          </motion.div>
        )}
      </AnimatePresence>
    </div>
  );
}

/* ── Elements Panel ───────────────────────────────────────── */

function ElementsPanel() {
  const [selectedElement, setSelectedElement] = React.useState<ElementType>("Fire");
  const elements: ElementType[] = ["Fire", "Earth", "Air", "Water"];
  const content = ELEMENTS_LEARN[selectedElement];
  const ui = elementUIConfig[selectedElement];
  const Icon = ELEMENT_ICON_MAP[selectedElement];

  return (
    <div className="flex gap-6 h-full min-h-0">
      {/* Element cards */}
      <div className="flex-1 min-w-0">
        <div className="grid grid-cols-2 gap-3 mb-5">
          {elements.map((el) => {
            const elUI = elementUIConfig[el];
            const elIcon = ELEMENT_ICON_MAP[el];
            const elContent = ELEMENTS_LEARN[el];
            const isSelected = selectedElement === el;
            return (
              <motion.button
                key={el}
                onClick={() => setSelectedElement(el)}
                className={cn(
                  "group relative flex flex-col items-center gap-2 p-4 rounded-xl border transition-all duration-300 cursor-pointer overflow-hidden",
                  isSelected
                    ? "border-border/60 bg-card/60"
                    : "bg-card/30 border-border/30 hover:bg-card/50 hover:border-border/60",
                )}
                whileTap={{ scale: 0.97 }}
              >
                {/* Glow bg for selected */}
                {isSelected && (
                  <div
                    className="absolute inset-0 opacity-10"
                    style={{
                      background: `radial-gradient(ellipse at center, ${elUI.styles.primary} 0%, transparent 70%)`,
                    }}
                  />
                )}
                <div className="relative size-14">
                  <img
                    src={elUI.frameUrl}
                    alt={`${el} frame`}
                    className="size-full object-contain"
                  />
                </div>
                <p
                  className={cn(
                    "text-xs font-serif tracking-tight transition-colors relative",
                    isSelected ? "text-foreground" : "text-muted-foreground group-hover:text-foreground",
                  )}
                >
                  {el}
                </p>
                <p className="text-[9px] text-muted-foreground/70 relative">
                  {elContent.tagline}
                </p>
              </motion.button>
            );
          })}
        </div>

        {/* Keywords strip */}
        <AnimatePresence mode="wait">
          <motion.div
            key={selectedElement}
            initial={{ opacity: 0, y: 5 }}
            animate={{ opacity: 1, y: 0 }}
            exit={{ opacity: 0, y: -5 }}
            transition={{ duration: 0.2 }}
            className="flex gap-2 flex-wrap"
          >
            {content.keywords.map((kw) => (
              <span
                key={kw}
                className="text-[10px] uppercase tracking-wider font-medium px-2.5 py-1 rounded-full border"
                style={{
                  borderColor: `${ui.styles.primary}30`,
                  backgroundColor: `${ui.styles.primary}08`,
                  color: ui.styles.primary,
                }}
              >
                {kw}
              </span>
            ))}
          </motion.div>
        </AnimatePresence>
      </div>

      {/* Selected element detail */}
      <AnimatePresence mode="wait">
        <motion.div
          key={selectedElement}
          initial={{ opacity: 0, x: 20 }}
          animate={{ opacity: 1, x: 0 }}
          exit={{ opacity: 0, x: -20 }}
          transition={{ duration: 0.3, ease: "easeOut" }}
          className="w-[280px] shrink-0 border-l border-border/30 pl-6 flex flex-col overflow-y-auto"
        >
          {/* Large element frame */}
          <div className="relative mx-auto mb-4">
            <div
              className="absolute inset-0 blur-2xl opacity-25 scale-125"
              style={{ backgroundColor: ui.styles.primary }}
            />
            <img
              src={ui.frameUrl}
              alt={`${selectedElement} frame`}
              className="relative size-40 object-contain"
            />
          </div>

          <div className="space-y-3 flex-1">
            <div>
              <h4 className="text-lg font-serif tracking-tight text-foreground">
                {selectedElement}
              </h4>
              <p className="text-[10px] uppercase tracking-[0.2em] font-bold" style={{ color: ui.styles.primary }}>
                {content.tagline}
              </p>
            </div>

            <div className="flex gap-1.5 flex-wrap">
              {content.signs.map((s) => (
                <span
                  key={s}
                  className="text-[9px] uppercase tracking-widest font-medium px-2 py-0.5 rounded-full bg-card border border-border/40 text-muted-foreground"
                >
                  {s}
                </span>
              ))}
            </div>

            <p className="text-[11px] text-muted-foreground leading-relaxed">
              {content.motivation}
            </p>

            <div className="pt-1">
              <p className="text-[9px] uppercase tracking-widest text-muted-foreground/60 font-medium mb-1.5">
                Strengths
              </p>
              <ul className="space-y-0.5">
                {content.strengths.slice(0, 3).map((s, i) => (
                  <li key={i} className="text-[11px] text-muted-foreground flex items-start gap-1.5">
                    <span className="mt-1.5 size-1 rounded-full shrink-0" style={{ backgroundColor: `${ui.styles.primary}60` }} />
                    {s}
                  </li>
                ))}
              </ul>
            </div>

            <div className="pt-1">
              <p className="text-[9px] uppercase tracking-widest text-muted-foreground/60 font-medium mb-1.5">
                Growth
              </p>
              <p className="text-[11px] text-muted-foreground leading-relaxed">
                {content.growth}
              </p>
            </div>
          </div>
        </motion.div>
      </AnimatePresence>
    </div>
  );
}

/* ── Main Learn Slide ─────────────────────────────────────── */

interface LearnSlideProps {
  isActive?: boolean;
  wasActive?: boolean;
}

export function LearnSlide({ isActive, wasActive }: LearnSlideProps) {
  const [activeTab, setActiveTab] = React.useState<TabId>("signs");

  const activeTabDef = TABS.find((t) => t.id === activeTab)!;

  return (
    <div className="grid grid-cols-[auto_1fr] gap-0 h-full items-stretch max-w-[1400px] mx-auto w-full overflow-hidden">
      {/* ── Left Column: Title + Vertical Tab Rail ── */}
      <motion.div
        className="flex flex-col w-[180px] shrink-0 border-r border-border/30 pr-0"
        initial={{ opacity: 0, x: -30 }}
        animate={isActive ? { opacity: 1, x: 0 } : { opacity: 0, x: -30 }}
        transition={{ duration: 0.5, ease: "easeOut" }}
      >
        {/* Title block */}
        <div className="pt-8 pb-6 pr-6">
          <motion.span
            initial={{ opacity: 0, y: 8 }}
            animate={isActive ? { opacity: 1, y: 0 } : {}}
            transition={{ delay: 0.1, duration: 0.4 }}
            className="inline-block text-[10px] uppercase tracking-[0.25em] font-bold px-3 py-1 rounded-full border bg-primary/5 border-primary/10 text-primary mb-4"
          >
            Zodiac Library
          </motion.span>
          <motion.h2
            initial={{ opacity: 0, y: 12 }}
            animate={isActive ? { opacity: 1, y: 0 } : {}}
            transition={{ delay: 0.15, duration: 0.5 }}
            className="text-4xl lg:text-5xl font-serif tracking-tight leading-[1.05]"
          >
            Learn
          </motion.h2>
          <motion.p
            initial={{ opacity: 0 }}
            animate={isActive ? { opacity: 1 } : {}}
            transition={{ delay: 0.25, duration: 0.4 }}
            className="text-muted-foreground text-[10px] uppercase tracking-widest font-medium mt-2"
          >
            The celestial archive
          </motion.p>
        </div>

        {/* Vertical tab rail */}
        <nav className="flex-1 flex flex-col gap-1 pr-4 pb-8">
          {TABS.map((tab, index) => {
            const Icon = tab.icon;
            const isActiveTab = activeTab === tab.id;
            return (
              <motion.button
                key={tab.id}
                onClick={() => setActiveTab(tab.id)}
                initial={{ opacity: 0, x: -10 }}
                animate={isActive ? { opacity: 1, x: 0 } : { opacity: 0, x: -10 }}
                transition={{
                  delay: 0.3 + index * 0.06,
                  duration: 0.3,
                }}
                className={cn(
                  "group relative flex items-center gap-3 px-3 py-2.5 rounded-lg text-left transition-all duration-300 cursor-pointer",
                  isActiveTab
                    ? "bg-card/80 border border-border/50"
                    : "hover:bg-card/30 border border-transparent",
                )}
              >
                {/* Active indicator bar */}
                <div
                  className={cn(
                    "absolute left-0 top-1/2 -translate-y-1/2 w-[3px] rounded-r-full transition-all duration-300",
                    isActiveTab ? "h-5" : "h-0 group-hover:h-3",
                  )}
                  style={{
                    backgroundColor: isActiveTab ? tab.accentColor : "var(--muted-foreground)",
                    opacity: isActiveTab ? 1 : 0.3,
                  }}
                />

                {/* Icon with glow for active tab */}
                <div className="relative">
                  {isActiveTab && (
                    <div
                      className="absolute inset-0 rounded-full blur-md opacity-40"
                      style={{ backgroundColor: tab.accentColor }}
                    />
                  )}
                  <Icon
                    className={cn(
                      "relative size-4 transition-colors duration-300",
                      isActiveTab ? "text-foreground" : "text-muted-foreground group-hover:text-foreground/80",
                    )}
                  />
                </div>

                <span
                  className={cn(
                    "text-sm font-medium tracking-wide transition-colors duration-300",
                    isActiveTab ? "text-foreground" : "text-muted-foreground group-hover:text-foreground/80",
                  })}
                >
                  {tab.label}
                </span>
              </motion.button>
            );
          })}
        </nav>
      </motion.div>

      {/* Right Column: Content Panel (2 col span) */}
      <motion.div
        className="flex flex-col h-full overflow-hidden pl-8 pr-10 py-8"
        initial={{ opacity: 0, y: 15 }}
        animate={isActive ? { opacity: 1, y: 0 } : { opacity: 0, y: 15 }}
        transition={{ duration: 0.5, ease: "easeOut", delay: 0.2 }}
      >
        {/* Tab header */}
        <div className="flex items-center gap-3 mb-5 shrink-0">
          <div
            className="size-1.5 rounded-full"
            style={{ backgroundColor: activeTabDef.accentColor }}
          />
          <h3 className="text-sm font-medium tracking-widest uppercase text-muted-foreground">
            {activeTabDef.label}
          </h3>
          <div className="flex-1 h-px bg-border/30" />
        </div>

        {/* Scrollable content */}
        <div className="flex-1 min-h-0 overflow-y-auto custom-scrollbar pr-2">
          <AnimatePresence mode="wait">
            <motion.div
              key={activeTab}
              initial={{ opacity: 0, y: 10 }}
              animate={{ opacity: 1, y: 0 }}
              exit={{ opacity: 0, y: -10 }}
              transition={{ duration: 0.25, ease: "easeOut" }}
            >
              {activeTab === "signs" && <SignsPanel />}
              {activeTab === "houses" && <HousesPanel />}
              {activeTab === "planets" && <PlanetsPanel />}
              {activeTab === "aspects" && <AspectsPanel />}
              {activeTab === "elements" && <ElementsPanel />}
            </motion.div>
          </AnimatePresence>
        </div>
      </motion.div>
    </div>
  );
}
